{
  "expo": {
    "name": "CatLovers",
    "slug": "catlovers",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8EFE8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.catlovers.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8EFE8"
      },
      "package": "com.catlovers.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden",
          "behavior": "overlay-swipe",
          "position": "absolute",
          "legacyVisible": "sticky-immersive"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "O CatLovers usa suas fotos apenas para personalizar o perfil.",
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "7bf40cdb-53a4-4e98-acdb-5fd64cc55725"
      }
    }
  }
}
