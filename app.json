{
  "expo": {
    "name": "CatLovers",
    "slug": "catlovers",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.catlovers.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8EFE8"
      },
      "package": "com.catlovers.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "O CatLovers usa suas fotos apenas para personalizar o perfil.",
          "microphonePermission": false
        }
      ]
    ]
  }
}
